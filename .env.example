# Server-side (kept secret, used by /api/dify proxy)
DIFY_API_KEY=your-dify-api-key
# One of: workflow | chat   (workflow = /workflows/run, chat = /chat-messages)
DIFY_MODE=workflow
# Optional: override the base URL or full endpoint
# DIFY_BASE_URL=https://api.dify.ai/v1
# DIFY_ENDPOINT=https://api.dify.ai/v1/workflows/run

# Local dev only (direct-from-browser; DO NOT set in production)
# VITE_DIFY_API_KEY=your-dify-api-key
# VITE_DIFY_MODE=workflow
# VITE_DIFY_ENDPOINT=https://api.dify.ai/v1/workflows/run
